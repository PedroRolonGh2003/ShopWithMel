# ═══ VERCEL (producción) — pegar en Vercel → Settings → Environment Variables ═══

DB_HOST=mysql-d95859c-est-daa.f.aivencloud.com
DB_PORT=14201
DB_USER=avnadmin
DB_PASSWORD=tu_password
DB_NAME=defaultdb

# Pega el contenido completo del archivo ca.pem (Aiven → CA Certificate → Download)
# En una sola línea con \n entre líneas, o multiline si Vercel lo permite:
DB_SSL_CA_CONTENT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

JWT_SECRET=genera-un-string-largo-aleatorio-min-32-chars
JWT_EXPIRES_IN=12h
NODE_ENV=production

# Tu URL de Vercel (ej. https://shop-with-mel.vercel.app)
CLIENT_ORIGIN=https://TU-PROYECTO.vercel.app

# ═══ LOCAL (desarrollo) ═══════════════════════════════════════
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=shop_with_mel
# CLIENT_ORIGIN=http://localhost:5173

PORT=4000
EXCEL_PATH=./data/ventas.xlsx
