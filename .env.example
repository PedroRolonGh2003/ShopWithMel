# ──────────────────────────────────────────────────────────────
#  Shop With Mel — Variables de entorno
#  Copia este archivo a .env y rellena con tus credenciales reales.
#  NUNCA subas el .env al repositorio.
# ──────────────────────────────────────────────────────────────

# Base de datos (Aiven MySQL)
DB_HOST=mysql-shopwithmel-xxx.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=tu_password_de_aiven
DB_NAME=defaultdb

# Ruta absoluta o relativa al certificado CA de Aiven (descárgalo del panel)
DB_SSL_CA=./certs/aiven-ca.pem

# Servidor
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET=cambia-esto-por-un-string-largo-y-aleatorio-min-32-chars
JWT_EXPIRES_IN=12h

# CORS — orígen del frontend en desarrollo
CLIENT_ORIGIN=http://localhost:5173

# Archivo Excel acumulado de ventas
EXCEL_PATH=./data/ventas.xlsx
